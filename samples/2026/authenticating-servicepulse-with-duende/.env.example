# Copy to .env, edit the two values under "Required edits", then:
#   docker compose up -d

# region RequiredEdits
# RabbitMQ connection string. The vhost, user, and management-API tag
# should already exist (see Part 1, "A clean slot in RabbitMQ").
# host.docker.internal resolves to the Docker host from inside the
# ServiceControl and audit containers via the extra_hosts entries in
# docker-compose.yml.
RABBITMQ_CONNECTIONSTRING=host=host.docker.internal;username=auth-poc;password=changeme;virtualHost=auth-poc

# Particular Software license. Paste the contents of your license.xml
# as one line.
PARTICULAR_LICENSE=
# endregion

# region Domains
# Public URL of the Duende IdentityServer, as the browser sees it.
# Used by ServiceControl as the OIDC authority and by Duende as the
# canonical issuer once the forwarded headers are honoured.
IDENTITYSERVER_PUBLIC_URL=https://is.<yourdomain>

# Public URL of ServicePulse / ServiceControl. Duende uses it to
# populate the servicepulse client's RedirectUris and CORS origin.
SERVICEPULSE_URL=https://sc.<yourdomain>
# endregion

# region OIDC
# The OIDC authority is Duende's root URL, no /realms/<name> suffix
# like Keycloak; Duende serves its discovery document at the root.
OIDC_AUTHORITY=${IDENTITYSERVER_PUBLIC_URL}

# Must match the ApiResource name in Config.cs.
OIDC_AUDIENCE=servicecontrol-api

# Client ID of the public ServicePulse client defined in Config.cs.
OIDC_SERVICEPULSE_CLIENTID=servicepulse

# Scopes ServicePulse requests at login, as a JSON-encoded array.
# Same shape as the Keycloak stack.
OIDC_SERVICEPULSE_APISCOPES=["openid","profile","email","servicecontrol-api"]
# endregion

# region Transport
# The transport ServiceControl uses to read from your RabbitMQ instance.
TRANSPORT_TYPE=RabbitMQ.QuorumConventionalRouting
# endregion

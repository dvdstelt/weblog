# Copy to .env, edit the two values under "Required edits", then:
#   docker compose up -d

# region RequiredEdits
# RabbitMQ connection string. The vhost and user should already exist
# (see post 1, "A clean slot in RabbitMQ"). host.docker.internal
# resolves to the Docker host from inside the ServiceControl and audit
# containers via the extra_hosts entries in docker-compose.yml, no
# shared docker network needed, and RabbitMQ's port has to be exposed
# on the host (the default 5672).
RABBITMQ_CONNECTIONSTRING=host=host.docker.internal;username=auth-poc;password=changeme;virtualHost=auth-poc

# Particular Software license. Paste the contents of your license.xml as
# one line, or comment this out and use the license-file volume mount
# block in docker-compose.yml.
PARTICULAR_LICENSE=
# endregion

# region Domains
# Public URL of Keycloak, as the browser sees it. Used for KC_HOSTNAME
# and as the OIDC authority.
KEYCLOAK_PUBLIC_URL=https://kc.<yourdomain>

# Realm name in Keycloak. The series uses "particular" throughout.
KEYCLOAK_REALM=particular
# endregion

# region Keycloak
# Initial admin credentials. Keycloak only honours these the first time
# the container starts against an empty database; change the password
# from inside the admin console after that.
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=changeme
# endregion

# region OIDC
# Derived from KEYCLOAK_PUBLIC_URL and KEYCLOAK_REALM. Leave as-is.
OIDC_AUTHORITY=${KEYCLOAK_PUBLIC_URL}/realms/${KEYCLOAK_REALM}

# Must match the "Included Custom Audience" set on the audience mapper
# in the servicecontrol-api client scope.
OIDC_AUDIENCE=servicecontrol-api

# Client ID of the ServicePulse public client in Keycloak.
OIDC_SERVICEPULSE_CLIENTID=servicepulse

# Scopes ServicePulse requests at login, as a JSON-encoded array.
# ServiceControl passes this value through to ServicePulse via
# /api/configuration, and ServicePulse JSON.parse's it on load.
# "servicecontrol-api" is the scope that pulls in the audience mapper.
OIDC_SERVICEPULSE_APISCOPES=["openid","profile","email","servicecontrol-api"]
# endregion

# region Transport
# The transport ServiceControl uses to read from your RabbitMQ instance.
# See https://docs.particular.net/servicecontrol/transports for the full list.
TRANSPORT_TYPE=RabbitMQ.QuorumConventionalRouting
# endregion

<script>
function keyToItem(currentItemIndex, previousItemIndex, originalInputValue) {
var currentItem = document.getElementById('suggestion-item-' + currentItemIndex);
var previousItem = document.getElementById('suggestion-item-' + previousItemIndex);
if(currentItem) {
currentItem.classList.add('bg-selected');
}
if(previousItem) {
previousItem.classList.remove('bg-selected');
}
var input = document.getElementById('searchRedesignTemplateInput');
if (currentItemIndex === -1) {
input.value = originalInputValue;
} else if(document.getElementsByClassName('js-suggestionitem')[currentItemIndex]) {
var newInputValue = document.getElementsByClassName('js-suggestionitem')[currentItemIndex].innerText;
input.value = newInputValue;
}
}
var input = document.getElementById('searchRedesignTemplateInput');
var currentItemIndex = -1;
var originalInputValue = '';
if(input) {
input.addEventListener('keyup', function(event) {
event.preventDefault();
var suggestionItems = document.querySelectorAll('.category-brand .item');
var selectedItem;
var previousItemIndex = currentItemIndex;
if (!event.shiftKey) { // allow for shift+arrow text highlighting
switch (event.key) {
case 'Escape':
input.blur();
break;
case 'Left': // for IE/Edge - empty case
case 'ArrowLeft': // empty case
case 'Right': // for IE/Edge - empty case
case 'ArrowRight':
selectedItem = document.querySelector('.bg-selected');
if (selectedItem) {
selectedItem.classList.remove('bg-selected');
}
currentItemIndex = -1;
break;
case 'Up': // for IE/Edge - empty case
case 'ArrowUp':
if (suggestionItems.length > 0) {
if(currentItemIndex === -1) {
currentItemIndex = suggestionItems.length - 1;
} else {
currentItemIndex--;
}
keyToItem(currentItemIndex, previousItemIndex, originalInputValue);
}
break;
case 'Down': // for IE/Edge - empty case
case 'ArrowDown':
if (suggestionItems.length > 0) {
if(currentItemIndex === suggestionItems.length - 1) {
currentItemIndex = -1;
} else {
currentItemIndex++;
}
keyToItem(currentItemIndex, previousItemIndex, originalInputValue);
}
break;
default: // Non-arrow/escape keys
currentItemIndex = -1;
originalInputValue = input.value;
break;
}
}
})
};
</script>

<script>
if ("undefined" === typeof(_etmc)) {
var _etmc = [];
}
function getCookie(cname) {
var name = cname + '=';
var decodedCookie = decodeURIComponent(document.cookie);
var ca = decodedCookie.split(';');
for (var i = 0; i < ca.length; i++) {
var c = ca[i];
while (c.charAt(0) === ' ') {
c = c.substring(1);
}
if (c.indexOf(name) === 0) {
return c.substring(name.length, c.length);
}
}
return '';
}
/**
* Builds Customer
*/
function buildCustomer() {
if(_etmc) {
_etmc.user_info={};
}
var cookieEmailID = getCookie('mc_customer_email');
var customerDetails = getCookie('mc_customer_data');
customerDetails = customerDetails.substring(customerDetails.indexOf('"') + 1, customerDetails.lastIndexOf('"'));
if (customerDetails.length > 0) {
var strArray = customerDetails.split(',');
var details = {
customerNo: strArray[3],
firstName: strArray[0],
lastName: strArray[1]
};
if(_etmc) {
_etmc.push(["setUserInfo",{"email":strArray[2],"details":{"customerNo":details.customerNo,"firstName":details.firstName,"lastName":details.lastName}}]);
}
} else {
var emailID;
emailID = cookieEmailID;
if (_etmc.user_info.details){
delete _etmc.user_info.details;
}
if(_etmc) {
_etmc.push(["setUserInfo",{"email":emailID}]);
}
}
}
buildCustomer();
</script>

---
// Pagefind UI is wired up client-side in the script below.
// The @pagefind/default-ui CSS is imported in Base.astro styles.
---
<div class="search">
  <div class="container">
    <div class="row">
      <div class="col col-12">
        <div class="search__box">
          <div class="search__group">
            <div class="search__close" id="js-search-close">
              <i class="ion ion-md-close"></i>
            </div>
            <div id="pagefind-search"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

---
// No @pagefind/default-ui CSS — we render results ourselves via the raw Pagefind API.
---
<div class="search" id="search-overlay">
  <div class="search__panel" role="dialog" aria-modal="true" aria-label="Search posts">

    <div class="search__input-wrap">
      <i class="ion ion-md-search search__icon" aria-hidden="true"></i>
      <input
        type="text"
        id="search-input"
        class="search__input"
        placeholder="Type to search..."
        autocomplete="off"
        spellcheck="false"
        aria-label="Search posts"
        aria-controls="search-results"
        aria-autocomplete="list"
      />
      <button class="search__close" id="js-search-close" aria-label="Close search">
        <i class="ion ion-md-close"></i>
      </button>
    </div>

    <p class="search__meta" id="search-meta" aria-live="polite"></p>

    <ul class="search__results" id="search-results" role="listbox" aria-label="Search results"></ul>

    <div class="search__footer" aria-hidden="true">
      <span><kbd>↑</kbd><kbd>↓</kbd> navigate</span>
      <span><kbd>↵</kbd> open</span>
      <span><kbd>esc</kbd> close</span>
    </div>

  </div>
</div>

<script>
  const MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

  function dateFromUrl(url: string): string {
    const m = url.match(/\/(\d{4})\/(\d{2})\/(\d{2})\//);
    return m ? `${MONTHS[+m[2] - 1]} ${+m[3]}, ${m[1]}` : '';
  }

  function highlightQuery(text: string, query: string): string {
    if (!query.trim()) return text;
    const escaped = query.trim().split(/\s+/)
      .filter(Boolean)
      .map(w => w.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'))
      .join('|');
    return text.replace(new RegExp(`(${escaped})`, 'gi'), '<mark>$1</mark>');
  }

  // ---- Pagefind raw API ----
  let pf: any = null;

  async function getPagefind() {
    if (pf) return pf;
    try {
      // Dynamic path via Function() bypasses Rollup static analysis.
      // pagefind.js is generated by `npx pagefind` after the build and
      // does not exist as a source file, so a direct import() would fail at bundle time.
      const load = new Function('u', 'return import(u)') as (u: string) => Promise<any>;
      pf = await load('/pagefind/pagefind.js');
      await pf.init();
    } catch {
      // Not available in dev mode (no built index yet).
    }
    return pf;
  }

  // ---- Keyboard selection state ----
  let selectedIdx = -1;
  let debounceTimer = 0;

  function resultItems(): HTMLElement[] {
    return [...document.querySelectorAll<HTMLElement>('#search-results .search__result')];
  }

  function setSelected(idx: number) {
    const items = resultItems();
    if (!items.length) return;
    const next = Math.max(-1, Math.min(idx, items.length - 1));
    items.forEach((el, i) => {
      el.classList.toggle('is-selected', i === next);
      el.querySelector('a')?.setAttribute('tabindex', i === next ? '0' : '-1');
    });
    selectedIdx = next;
    if (next >= 0) items[next].scrollIntoView({ block: 'nearest', behavior: 'smooth' });
  }

  function openSelected() {
    const items = resultItems();
    const target = selectedIdx >= 0 ? items[selectedIdx] : items[0];
    target?.querySelector<HTMLAnchorElement>('a')?.click();
  }

  // ---- Render helpers ----
  function renderResults(results: any[], query: string) {
    const list  = document.getElementById('search-results')!;
    const meta  = document.getElementById('search-meta')!;
    selectedIdx = -1;

    if (!results.length) {
      meta.textContent = '';
      list.innerHTML = `<li class="search__empty">No results for <em>${query}</em></li>`;
      return;
    }

    const n = results.length;
    meta.textContent = `${n} result${n === 1 ? '' : 's'}`;

    list.innerHTML = results.map((r, i) => {
      const title = highlightQuery(r.meta?.title ?? '', query);
      const date  = dateFromUrl(r.url);
      return `<li class="search__result" role="option" data-index="${i}">
        <a href="${r.url}" tabindex="${i === 0 ? '0' : '-1'}">
          <span class="search__result-title">${title}</span>
          ${date ? `<span class="search__result-date">${date}</span>` : ''}
        </a>
      </li>`;
    }).join('');
  }

  function clearResults() {
    document.getElementById('search-results')!.innerHTML = '';
    document.getElementById('search-meta')!.textContent  = '';
    selectedIdx = -1;
  }

  // ---- Search ----
  async function doSearch(query: string) {
    if (!query.trim()) { clearResults(); return; }
    const pagefind = await getPagefind();
    if (!pagefind) return;
    const { results } = await pagefind.search(query);
    const data = await Promise.all(results.slice(0, 20).map((r: any) => r.data()));
    renderResults(data, query);
  }

  // ---- Wire up ----
  document.addEventListener('DOMContentLoaded', () => {
    const input   = document.getElementById('search-input') as HTMLInputElement;
    const overlay = document.querySelector<HTMLElement>('.search')!;

    // Focus input and clear stale results when the panel opens; clear when it closes.
    new MutationObserver(() => {
      if (overlay.classList.contains('is-visible')) {
        setTimeout(() => input.focus(), 60);
        getPagefind(); // warm up the index in the background
      } else {
        clearResults();
        input.value = '';
      }
    }).observe(overlay, { attributes: true, attributeFilter: ['class'] });

    // Live search — debounced 150 ms
    input.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      debounceTimer = window.setTimeout(() => doSearch(input.value), 150);
    });

    // Keyboard navigation within the results list
    input.addEventListener('keydown', (e: KeyboardEvent) => {
      const items = resultItems();
      if (!items.length && e.key !== 'Escape') return;
      switch (e.key) {
        case 'ArrowDown':
          e.preventDefault();
          setSelected(selectedIdx + 1);
          break;
        case 'ArrowUp':
          e.preventDefault();
          setSelected(selectedIdx <= 0 ? -1 : selectedIdx - 1);
          break;
        case 'Enter':
          e.preventDefault();
          openSelected();
          break;
      }
    });
  });
</script>

---
import '@pagefind/default-ui/css/ui.css';
---
<div class="search">
  <div class="container">
    <div class="row">
      <div class="col col-12">
        <div class="search__box">
          <div class="search__group">
            <button class="search__close" id="js-search-close" aria-label="Close search">
              <i class="ion ion-md-close"></i>
            </button>
            <div id="pagefind-search"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  import { PagefindUI } from '@pagefind/default-ui';

  const MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

  function formatDateFromUrl(href: string): string | null {
    const m = href.match(/\/(\d{4})\/(\d{2})\/(\d{2})\//);
    if (!m) return null;
    return `${MONTHS[+m[2] - 1]} ${+m[3]}, ${m[1]}`;
  }

  // Inject a date line below each result title, derived from the result URL.
  // Also strips Svelte-scoped classes from <li> elements — those classes add an
  // extra border-top that conflicts with our own border-bottom divider.
  // Runs after every batch of results Pagefind adds to the DOM.
  function processResults() {
    // Remove svelte-scoped classes from result <li> elements
    document.querySelectorAll<HTMLLIElement>('#pagefind-search li').forEach(li => {
      for (const cls of [...li.classList]) {
        if (cls.startsWith('svelte-')) li.classList.remove(cls);
      }
    });

    // Inject formatted date below each title
    document.querySelectorAll<HTMLElement>('.pagefind-ui__result-title:not([data-dated])').forEach(titleEl => {
      const link = titleEl.querySelector<HTMLAnchorElement>('.pagefind-ui__result-link');
      if (!link) return;
      const dateStr = formatDateFromUrl(link.href);
      if (!dateStr) return;
      titleEl.setAttribute('data-dated', '');
      const p = document.createElement('p');
      p.className = 'search-result-date';
      p.textContent = dateStr;
      titleEl.insertAdjacentElement('afterend', p);
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    new PagefindUI({
      element: '#pagefind-search',
      showImages: false,
      showSubResults: false,
    });

    // Set placeholder — Pagefind renders synchronously so this works immediately.
    const input = document.querySelector<HTMLInputElement>('#pagefind-search .pagefind-ui__search-input');
    if (input) input.placeholder = 'Type to search...';

    // Watch for results being added/updated and run post-processing.
    // We observe #pagefind-search (not the ol, which may not exist yet).
    const container = document.getElementById('pagefind-search');
    if (container) {
      new MutationObserver(processResults).observe(container, { childList: true, subtree: true });
    }
  });
</script>

---
const socialLinks = [
  { icon: 'ion-logo-twitter',  href: 'https://twitter.com/dvdstelt' },
  { icon: 'ion-logo-github',   href: 'https://github.com/dvdstelt' },
  { icon: 'ion-logo-linkedin', href: 'https://www.linkedin.com/in/dvdstelt/' },
  { icon: 'ion-logo-whatsapp', href: 'https://api.whatsapp.com/send?phone=%2B31648536810' },
];
---
<div class="social">
  <ul class="social__list list-reset">
    {socialLinks.map(({ icon, href }) => (
      <li class="social__item">
        <a class="social__link" href={href} aria-label="social icon">
          <i class={`ion ${icon}`}></i>
        </a>
      </li>
    ))}
  </ul>
</div>

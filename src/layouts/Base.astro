---
import Head from '../components/Head.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/main.scss';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  pubDate?: Date;
}

const { title, description, image, pubDate } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <Head
    title={title}
    description={description}
    image={image}
    pubDate={pubDate}
    canonicalURL={Astro.url.href}
  />

  <body>
    <Header />

    <!-- begin content -->
    <main class="content" aria-label="Content">
      <slot />
    </main>
    <!-- end content -->

    <div class="top" title="Top"><i class="ion ion-ios-arrow-up"></i></div>

    <Footer />

    <script>
      // Menu open/close
      const menuOpenIcon = document.querySelector('.nav__icon-menu');
      const menuCloseIcon = document.querySelector('.nav__icon-close');
      const menuList = document.querySelector('.menu-overlay');
      const searchOpenIcon = document.querySelector('.nav__icon-search');
      const searchCloseIcon = document.querySelector('#js-search-close');
      const searchBox = document.querySelector('.search');
      const topButton = document.querySelector('.top');

      menuOpenIcon?.addEventListener('click', () => menuList?.classList.add('is-open'));
      menuCloseIcon?.addEventListener('click', () => menuList?.classList.remove('is-open'));

      searchOpenIcon?.addEventListener('click', () => {
        searchBox?.classList.add('is-visible');
      });
      searchCloseIcon?.addEventListener('click', () => searchBox?.classList.remove('is-visible'));

      searchBox?.addEventListener('click', (e) => {
        if (e.target === searchBox) searchBox.classList.remove('is-visible');
      });
      document.addEventListener('keyup', (e) => {
        if (e.key === 'Escape') searchBox?.classList.remove('is-visible');
      });

      // Page load animation
      setTimeout(() => document.body.classList.add('is-in'), 150);

      // Scroll-to-top button
      topButton?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
      window.addEventListener('scroll', () => {
        topButton?.classList.toggle('is-active', window.scrollY > window.innerHeight);
      });

      // Code block hover-expand: let the pre grow beyond the content column
      // to the viewport edge without adding a page-level horizontal scrollbar.
      // Technique: when <html> has no explicit overflow, <body>'s overflow-x
      // propagates to the viewport. Setting html to 'hidden' takes ownership
      // of the viewport, freeing body to 'visible' so descendants can overflow
      // the column — clipped only by the viewport, not by body.
      document.querySelectorAll<HTMLElement>(
        '.post__content pre, .page__content pre'
      ).forEach((pre) => {
        pre.addEventListener('mouseenter', () => {
          document.documentElement.style.overflowX = 'hidden';
          document.body.style.overflowX = 'visible';
        });
        pre.addEventListener('mouseleave', () => {
          document.documentElement.style.overflowX = '';
          document.body.style.overflowX = '';
        });
      });

      // Lightbox for standalone images in post/page content
      (() => {
        const overlay = document.createElement('div');
        overlay.className = 'lightbox-overlay';
        const overlayImg = document.createElement('img');
        overlay.appendChild(overlayImg);
        document.body.appendChild(overlay);

        const close = () => overlay.classList.remove('is-open');

        overlay.addEventListener('click', close);
        document.addEventListener('keyup', (e) => {
          if (e.key === 'Escape') close();
        });

        document.querySelectorAll<HTMLImageElement>(
          '.post__content img, .page__content img'
        ).forEach((img) => {
          if (img.closest('a')) return;
          img.addEventListener('click', () => {
            overlayImg.src = img.src;
            overlayImg.alt = img.alt;
            overlay.classList.add('is-open');
          });
        });
      })();

      // Lite YouTube embeds: replace iframes with thumbnail + play button
      document.querySelectorAll<HTMLIFrameElement>(
        '.post__content iframe[src*="youtube.com/embed"], .page__content iframe[src*="youtube.com/embed"]'
      ).forEach((iframe) => {
        const src = iframe.getAttribute('src')?.trim() ?? '';
        const match = src.match(/youtube\.com\/embed\/([^?&\s]+)/);
        if (!match) return;

        const videoId = match[1];

        const wrapper = document.createElement('div');
        wrapper.className = 'yt-embed';

        const img = document.createElement('img');
        img.src = `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`;
        img.alt = 'YouTube video';
        img.loading = 'lazy';
        img.onerror = () => { img.src = `https://img.youtube.com/vi/${videoId}/hqdefault.jpg`; };

        const btn = document.createElement('button');
        btn.className = 'yt-embed__play';
        btn.setAttribute('aria-label', 'Play video');
        btn.innerHTML = '<i class="ion ion-ios-play"></i>';

        wrapper.appendChild(img);
        wrapper.appendChild(btn);
        iframe.replaceWith(wrapper);

        wrapper.addEventListener('click', () => {
          const playIframe = document.createElement('iframe');
          playIframe.src = `https://www.youtube.com/embed/${videoId}?autoplay=1`;
          playIframe.setAttribute('allowfullscreen', '');
          playIframe.setAttribute('allow', 'autoplay; encrypted-media; picture-in-picture');
          playIframe.className = 'yt-embed__player';
          wrapper.replaceWith(playIframe);
        }, { once: true });
      });
    </script>
  </body>
</html>

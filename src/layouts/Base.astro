---
import Head from '../components/Head.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/main.scss';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  pubDate?: Date;
}

const { title, description, image, pubDate } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <Head
    title={title}
    description={description}
    image={image}
    pubDate={pubDate}
    canonicalURL={Astro.url.href}
  />

  <body>
    <Header />

    <!-- begin content -->
    <main class="content" aria-label="Content">
      <slot />
    </main>
    <!-- end content -->

    <div class="top" title="Top"><i class="ion ion-ios-arrow-up"></i></div>

    <Footer />

    <script>
      // Menu open/close
      const menuOpenIcon = document.querySelector('.nav__icon-menu');
      const menuCloseIcon = document.querySelector('.nav__icon-close');
      const menuList = document.querySelector('.menu-overlay');
      const searchOpenIcon = document.querySelector('.nav__icon-search');
      const searchCloseIcon = document.querySelector('#js-search-close');
      const searchBox = document.querySelector('.search');
      const topButton = document.querySelector('.top');

      menuOpenIcon?.addEventListener('click', () => menuList?.classList.add('is-open'));
      menuCloseIcon?.addEventListener('click', () => menuList?.classList.remove('is-open'));

      searchOpenIcon?.addEventListener('click', () => {
        searchBox?.classList.add('is-visible');
      });
      searchCloseIcon?.addEventListener('click', () => searchBox?.classList.remove('is-visible'));

      searchBox?.addEventListener('click', (e) => {
        if (e.target === searchBox) searchBox.classList.remove('is-visible');
      });
      document.addEventListener('keyup', (e) => {
        if (e.key === 'Escape') searchBox?.classList.remove('is-visible');
      });

      // Page load animation
      setTimeout(() => document.body.classList.add('is-in'), 150);

      // Scroll-to-top button
      topButton?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
      window.addEventListener('scroll', () => {
        topButton?.classList.toggle('is-active', window.scrollY > window.innerHeight);
      });

      // Code block hover-expand: let the pre grow beyond the content column
      // to the viewport edge without adding a page-level horizontal scrollbar.
      // Technique: when <html> has no explicit overflow, <body>'s overflow-x
      // propagates to the viewport. Setting html to 'hidden' takes ownership
      // of the viewport, freeing body to 'visible' so descendants can overflow
      // the column — clipped only by the viewport, not by body.
      // We attach to the .code-block-wrapper when present so that moving the
      // mouse onto the copy button (a sibling of pre) does not collapse it.
      document.querySelectorAll<HTMLElement>(
        '.post__content pre, .page__content pre'
      ).forEach((pre) => {
        // Shiki injects overflow-x: auto as an inline style; remove it so our
        // stylesheet rule (overflow-x: hidden) applies instead.
        pre.style.removeProperty('overflow-x');

        const target: HTMLElement =
          pre.parentElement?.classList.contains('code-block-wrapper')
            ? pre.parentElement
            : pre;
        target.addEventListener('mouseenter', () => {
          document.documentElement.style.overflowX = 'hidden';
          document.body.style.overflowX = 'visible';
        });
        target.addEventListener('mouseleave', () => {
          document.documentElement.style.overflowX = '';
          document.body.style.overflowX = '';
        });
      });

      // Lightbox for standalone images in post/page content.
      // Images sharing the same parent element form a gallery group,
      // so consecutive images in markdown (same <p>) get prev/next nav.
      (() => {
        const overlay = document.createElement('div');
        overlay.className = 'lightbox-overlay';

        const overlayImg = document.createElement('img');

        const prevBtn = document.createElement('button');
        prevBtn.className = 'lightbox-prev';
        prevBtn.setAttribute('aria-label', 'Previous image');
        prevBtn.innerHTML = '<i class="ion ion-ios-arrow-back"></i>';

        const nextBtn = document.createElement('button');
        nextBtn.className = 'lightbox-next';
        nextBtn.setAttribute('aria-label', 'Next image');
        nextBtn.innerHTML = '<i class="ion ion-ios-arrow-forward"></i>';

        const counterEl = document.createElement('div');
        counterEl.className = 'lightbox-counter';

        overlay.appendChild(prevBtn);
        overlay.appendChild(overlayImg);
        overlay.appendChild(nextBtn);
        overlay.appendChild(counterEl);
        document.body.appendChild(overlay);

        let gallery: HTMLImageElement[] = [];
        let currentIndex = 0;

        const show = (index: number) => {
          currentIndex = index;
          const img = gallery[index];
          overlayImg.src = img.src;
          overlayImg.alt = img.alt;
          const multi = gallery.length > 1;
          prevBtn.classList.toggle('is-hidden', !multi);
          nextBtn.classList.toggle('is-hidden', !multi);
          counterEl.classList.toggle('is-hidden', !multi);
          if (multi) {
            counterEl.textContent = `${index + 1} / ${gallery.length}`;
            (prevBtn as HTMLButtonElement).disabled = index === 0;
            (nextBtn as HTMLButtonElement).disabled = index === gallery.length - 1;
          }
        };

        const close = () => {
          overlay.classList.remove('is-open');
          gallery = [];
        };

        prevBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          if (currentIndex > 0) show(currentIndex - 1);
        });
        nextBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          if (currentIndex < gallery.length - 1) show(currentIndex + 1);
        });

        // Close only when clicking the backdrop, not the image or buttons.
        overlay.addEventListener('click', (e) => {
          if (e.target === overlay) close();
        });
        document.addEventListener('keyup', (e) => {
          if (e.key === 'Escape') close();
          if (!overlay.classList.contains('is-open')) return;
          if (e.key === 'ArrowLeft'  && currentIndex > 0)                  show(currentIndex - 1);
          if (e.key === 'ArrowRight' && currentIndex < gallery.length - 1) show(currentIndex + 1);
        });

        document.querySelectorAll<HTMLImageElement>(
          '.post__content img, .page__content img'
        ).forEach((img) => {
          if (img.closest('a')) return;
          img.addEventListener('click', () => {
            // Build gallery from non-linked images sharing the same parent.
            const siblings = Array.from(
              img.parentElement?.querySelectorAll<HTMLImageElement>('img') ?? [img]
            ).filter(i => !i.closest('a'));
            gallery = siblings.length > 0 ? siblings : [img];
            show(gallery.indexOf(img));
            overlay.classList.add('is-open');
          });
        });
      })();

      // Lite YouTube embeds: replace iframes with thumbnail + play button
      document.querySelectorAll<HTMLIFrameElement>(
        '.post__content iframe[src*="youtube.com/embed"], .page__content iframe[src*="youtube.com/embed"]'
      ).forEach((iframe) => {
        const src = iframe.getAttribute('src')?.trim() ?? '';
        const match = src.match(/youtube\.com\/embed\/([^?&\s]+)/);
        if (!match) return;

        const videoId = match[1];

        const wrapper = document.createElement('div');
        wrapper.className = 'yt-embed';

        const img = document.createElement('img');
        img.src = `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`;
        img.alt = 'YouTube video';
        img.loading = 'lazy';
        img.onerror = () => { img.src = `https://img.youtube.com/vi/${videoId}/hqdefault.jpg`; };

        const btn = document.createElement('button');
        btn.className = 'yt-embed__play';
        btn.setAttribute('aria-label', 'Play video');
        btn.innerHTML = '<i class="ion ion-ios-play"></i>';

        wrapper.appendChild(img);
        wrapper.appendChild(btn);
        iframe.replaceWith(wrapper);

        wrapper.addEventListener('click', () => {
          const playIframe = document.createElement('iframe');
          playIframe.src = `https://www.youtube.com/embed/${videoId}?autoplay=1`;
          playIframe.setAttribute('allowfullscreen', '');
          playIframe.setAttribute('allow', 'autoplay; encrypted-media; picture-in-picture');
          playIframe.className = 'yt-embed__player';
          wrapper.replaceWith(playIframe);
        }, { once: true });
      });
    </script>
  </body>
</html>

---
import type { CollectionEntry } from 'astro:content';
import Base from './Base.astro';
import GiscusComments from '../components/GiscusComments.astro';
import { getPostUrl, tagSlug, readingTime } from '../lib/posts';

interface Props {
  post: CollectionEntry<'posts'>;
  prevPost?: CollectionEntry<'posts'>;
  nextPost?: CollectionEntry<'posts'>;
}

const { post, prevPost, nextPost } = Astro.props;
const { title, description, image, pubDate, tags = [] } = post.data;
const postUrl = getPostUrl(post);

const dateISO = pubDate.toISOString();
const dateFormatted = pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
const mins = readingTime(post.body ?? '');

const prevUrl = prevPost ? getPostUrl(prevPost) : null;
const nextUrl = nextPost ? getPostUrl(nextPost) : null;

const shareBase = Astro.site?.href.replace(/\/$/, '') ?? '';
const shareUrl = `${shareBase}${postUrl}`;
const shareTitle = encodeURIComponent(title);
const shareDesc = encodeURIComponent(description);
const githubUrl = `https://github.com/dvdstelt/weblog/blob/main/src/content/posts/${post.id}`;
---
<Base title={title} description={description} image={image} pubDate={pubDate}>
  {image && (
    <div class="container">
      <div class="row">
        <div class="col col-12">
          <div class="image-box">
            <img class="post-image" src={image} alt={title} />
            <div class="post-head post-head--overlay">
              <h1 class="post-title">{title}</h1>
              <div class="post__date-reading">
                <time datetime={dateISO}>{dateFormatted}</time>
                <span class="post__separator">·</span>
                <span class="post__reading-time">
                  <i class="ion ion-ios-time"></i> {mins} min read
                </span>
              </div>
              {tags.length > 0 && (
                <div class="post-tags">
                  {tags.map((tag) => (
                    <a href={`/tag/${tagSlug(tag)}/`} class="post-tags__tag">#{tag}</a>
                  ))}
                </div>
              )}
            </div>
          </div>
        </div>
      </div>
    </div>
  )}

  <div class="container">
    <div class="row">
      <div class="col col-8 col-d-10 push-2 push-d-1 col-t-12 push-t-0">
        <!-- begin post -->
        <article class="post animate">

          {!image && (
            <div class="post-head">
              <h1 class="post-title">{title}</h1>
              <div class="post__date-reading">
                <time datetime={dateISO}>{dateFormatted}</time>
                <span class="post__separator">·</span>
                <span class="post__reading-time">
                  <i class="ion ion-ios-time"></i> {mins} min read
                </span>
              </div>
              {tags.length > 0 && (
                <div class="post-tags">
                  {tags.map((tag) => (
                    <a href={`/tag/${tagSlug(tag)}/`} class="post-tags__tag">#{tag}</a>
                  ))}
                </div>
              )}
            </div>
          )}

          <div class="post__content" data-pagefind-body>
            {/* Visually hidden title copy with boosted weight so title matches rank higher in Pagefind */}
            <span data-pagefind-weight="10" style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap">{title}</span>
            <slot />
          </div>

          <div class="post__share">
            <div class="share__head">
              <div class="share__title">Share this article</div>
            </div>
            <ul class="share__list list-reset">
              <li class="share__item">
                <a class="share__link share__facebook"
                  href={`https://www.facebook.com/sharer/sharer.php?u=${shareUrl}`}
                  onclick="window.open(this.href,'pop-up','left=20,top=20,width=500,height=500,toolbar=1,resizable=0');return false;"
                  title="Share on Facebook" rel="nofollow">
                  <i class="ion ion-logo-facebook"></i>
                </a>
              </li>
              <li class="share__item">
                <a class="share__link share__twitter"
                  href={`https://twitter.com/intent/tweet?text=${shareTitle}&url=${shareUrl}`}
                  onclick="window.open(this.href,'pop-up','left=20,top=20,width=500,height=500,toolbar=1,resizable=0');return false;"
                  title="Share on Twitter" rel="nofollow">
                  <i class="ion ion-logo-twitter"></i>
                </a>
              </li>
              <li class="share__item">
                <a class="share__link share__linkedin"
                  href={`https://www.linkedin.com/shareArticle?mini=true&url=${shareUrl}&title=${shareTitle}&summary=${shareDesc}`}
                  onclick="window.open(this.href,'pop-up','left=20,top=20,width=500,height=500,toolbar=1,resizable=0');return false;"
                  title="Share on LinkedIn" rel="nofollow">
                  <i class="ion ion-logo-linkedin"></i>
                </a>
              </li>
              <li class="share__separator" aria-hidden="true"></li>
              <li class="share__item">
                <a class="share__link share__github"
                  href={githubUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  title="View on GitHub">
                  <i class="ion ion-logo-github"></i>
                </a>
              </li>
            </ul>
          </div>

          <div class="post__navigation">
            {prevUrl && (
              <a class="prev" href={prevUrl} style={prevPost?.data.image ? `background-image: url(${prevPost.data.image})` : undefined}>
                <div class="post__nav-box">
                  <div class="post__nav post__nav__prev">
                    <i class="ion ion-ios-arrow-back"></i> Previous Page
                  </div>
                  <h4 class="post__nav__title">{prevPost?.data.title}</h4>
                </div>
              </a>
            )}
            {nextUrl && (
              <a class="next" href={nextUrl} style={nextPost?.data.image ? `background-image: url(${nextPost.data.image})` : undefined}>
                <div class="post__nav-box">
                  <div class="post__nav post__nav__next">
                    Next Page <i class="ion ion-ios-arrow-forward"></i>
                  </div>
                  <h4 class="post__nav__title">{nextPost?.data.title}</h4>
                </div>
              </a>
            )}
          </div>

          <GiscusComments />

        </article>

        <!-- Full-screen viewer for inline d2 diagrams. Markup is empty until a
             diagram is clicked; the script clones the clicked SVG into .d2-zoom-content. -->
        <dialog class="d2-zoom-dialog" aria-label="Diagram viewer">
          <button type="button" class="d2-zoom-close" aria-label="Close diagram viewer">&times;</button>
          <div class="d2-zoom-stage" data-d2-zoom-stage>
            <div class="d2-zoom-center">
              <div class="d2-zoom-content" data-d2-zoom-content></div>
            </div>
          </div>
          <div class="d2-zoom-controls" role="group" aria-label="Zoom controls">
            <button type="button" class="d2-zoom-btn" data-d2-zoom-out aria-label="Zoom out">&minus;</button>
            <button type="button" class="d2-zoom-btn" data-d2-zoom-reset aria-label="Reset zoom">Reset</button>
            <button type="button" class="d2-zoom-btn" data-d2-zoom-in aria-label="Zoom in">+</button>
          </div>
          <p class="d2-zoom-hint">pinch or scroll to zoom, drag to pan, esc to close</p>
        </dialog>

        <script>
          // D2 diagram fullscreen viewer: click any .d2-diagram to open the SVG
          // in a fullscreen dialog with mouse-wheel zoom and click-drag pan.
          (function setupD2Zoom() {
            const dialog = document.querySelector('.d2-zoom-dialog');
            if (!dialog || typeof dialog.showModal !== 'function') return;
            const stage = dialog.querySelector('[data-d2-zoom-stage]');
            const content = dialog.querySelector('[data-d2-zoom-content]');
            const closeBtn = dialog.querySelector('.d2-zoom-close');
            const zoomInBtn = dialog.querySelector('[data-d2-zoom-in]');
            const zoomOutBtn = dialog.querySelector('[data-d2-zoom-out]');
            const zoomResetBtn = dialog.querySelector('[data-d2-zoom-reset]');

            const MIN_SCALE = 0.4;
            const MAX_SCALE = 10;

            let scale = 1;
            let tx = 0;
            let ty = 0;
            let dragging = false;
            let lastX = 0;
            let lastY = 0;
            // Active pointers on the stage, keyed by pointerId. One pointer
            // pans; two pointers pinch-zoom. This is what makes the viewer
            // usable on touch devices that have no scroll wheel.
            const pointers = new Map();
            let pinchDist = 0;
            // Track whether the viewer was opened by keyboard so we can
            // suppress the lingering focus ring on the trigger figure
            // after a mouse-initiated close. Keyboard users still get
            // focus restored to the trigger, which is what they need.
            let openedByKeyboard = false;

            function apply() {
              content.style.transform = `translate(${tx}px, ${ty}px) scale(${scale})`;
            }

            function reset() {
              scale = 1;
              tx = 0;
              ty = 0;
              apply();
            }

            // Zoom by `factor` while keeping the screen point (clientX, clientY)
            // anchored under the cursor / pinch midpoint. The content is centred
            // in the stage, so we work in coordinates relative to the stage centre.
            function zoomAt(clientX, clientY, factor) {
              const rect = stage.getBoundingClientRect();
              const px = clientX - (rect.left + rect.width / 2);
              const py = clientY - (rect.top + rect.height / 2);
              const newScale = Math.max(MIN_SCALE, Math.min(MAX_SCALE, scale * factor));
              const f = newScale / scale;
              if (f === 1) return;
              tx = px - (px - tx) * f;
              ty = py - (py - ty) * f;
              scale = newScale;
              apply();
            }

            // Zoom toward the centre of the stage (used by the +/- buttons).
            function zoomByButton(factor) {
              const rect = stage.getBoundingClientRect();
              zoomAt(rect.left + rect.width / 2, rect.top + rect.height / 2, factor);
            }

            function open(originalSvg, fromKeyboard) {
              const clone = originalSvg.cloneNode(true);
              // Strip width/height so CSS controls the size in the viewer.
              clone.removeAttribute('width');
              clone.removeAttribute('height');
              content.replaceChildren(clone);
              // Match the dialog chrome to the diagram's canvas fill so the
              // SVG extends seamlessly. d2 emits a root <rect> with the
              // canvas colour as its first descendant. Fall back to the CSS
              // default if anything looks off.
              const canvasRect = clone.querySelector('rect');
              const canvasFill = canvasRect?.getAttribute('fill');
              dialog.style.background = canvasFill || '';
              openedByKeyboard = fromKeyboard === true;
              reset();
              dialog.showModal();
            }

            function close() {
              dialog.close();
            }

            document.querySelectorAll('.post__content .d2-diagram').forEach((figure) => {
              figure.setAttribute('tabindex', '0');
              figure.setAttribute('role', 'button');
              figure.setAttribute('aria-label', 'Open diagram in fullscreen viewer');

              figure.addEventListener('click', () => {
                const svg = figure.querySelector('svg');
                if (svg) open(svg, false);
              });
              figure.addEventListener('keydown', (e) => {
                if (e.key === 'Enter' || e.key === ' ') {
                  e.preventDefault();
                  const svg = figure.querySelector('svg');
                  if (svg) open(svg, true);
                }
              });
            });

            closeBtn.addEventListener('click', close);
            zoomInBtn?.addEventListener('click', () => zoomByButton(1.3));
            zoomOutBtn?.addEventListener('click', () => zoomByButton(1 / 1.3));
            zoomResetBtn?.addEventListener('click', reset);
            // Click on the dialog itself (the backdrop area outside the stage) closes.
            dialog.addEventListener('click', (e) => {
              if (e.target === dialog) close();
            });
            // Cleanup after any close (button, backdrop click, ESC).
            dialog.addEventListener('close', () => {
              content.replaceChildren();
              dialog.style.background = '';
              pointers.clear();
              pinchDist = 0;
              dragging = false;
              stage.classList.remove('is-dragging');
              // Mouse open -> drop focus so Chrome doesn't paint a focus ring
              // around the figure when control returns to the page.
              if (!openedByKeyboard && document.activeElement instanceof HTMLElement) {
                document.activeElement.blur();
              }
            });

            stage.addEventListener('wheel', (e) => {
              e.preventDefault();
              const factor = e.deltaY < 0 ? 1.15 : 1 / 1.15;
              zoomAt(e.clientX, e.clientY, factor);
            }, { passive: false });

            stage.addEventListener('pointerdown', (e) => {
              pointers.set(e.pointerId, { x: e.clientX, y: e.clientY });
              stage.setPointerCapture(e.pointerId);
              if (pointers.size === 1) {
                dragging = true;
                lastX = e.clientX;
                lastY = e.clientY;
                stage.classList.add('is-dragging');
              } else if (pointers.size === 2) {
                // Second finger down: switch from pan to pinch-zoom.
                dragging = false;
                const pts = [...pointers.values()];
                pinchDist = Math.hypot(pts[0].x - pts[1].x, pts[0].y - pts[1].y);
              }
            });
            stage.addEventListener('pointermove', (e) => {
              if (!pointers.has(e.pointerId)) return;
              pointers.set(e.pointerId, { x: e.clientX, y: e.clientY });
              if (pointers.size >= 2) {
                const pts = [...pointers.values()];
                const dist = Math.hypot(pts[0].x - pts[1].x, pts[0].y - pts[1].y);
                const midX = (pts[0].x + pts[1].x) / 2;
                const midY = (pts[0].y + pts[1].y) / 2;
                if (pinchDist > 0 && dist > 0) zoomAt(midX, midY, dist / pinchDist);
                pinchDist = dist;
              } else if (dragging) {
                tx += e.clientX - lastX;
                ty += e.clientY - lastY;
                lastX = e.clientX;
                lastY = e.clientY;
                apply();
              }
            });
            function endDrag(e) {
              if (!pointers.has(e.pointerId)) return;
              pointers.delete(e.pointerId);
              try { stage.releasePointerCapture(e.pointerId); } catch {}
              if (pointers.size < 2) pinchDist = 0;
              if (pointers.size === 1) {
                // One finger left after a pinch: resume panning from it.
                const [p] = [...pointers.values()];
                dragging = true;
                lastX = p.x;
                lastY = p.y;
              } else if (pointers.size === 0) {
                dragging = false;
                stage.classList.remove('is-dragging');
              }
            }
            stage.addEventListener('pointerup', endDrag);
            stage.addEventListener('pointercancel', endDrag);
          })();

          document.querySelectorAll('.post__content pre').forEach((pre) => {
            const prev = pre.previousElementSibling;
            const sourceLink = prev?.classList.contains('code-source-link') ? prev : null;

            const wrapper = document.createElement('div');
            wrapper.className = 'code-block-wrapper';
            pre.parentNode?.insertBefore(wrapper, pre);
            wrapper.appendChild(pre);

            if (sourceLink) wrapper.appendChild(sourceLink);

            const button = document.createElement('button');
            button.className = 'code-copy-btn';
            button.setAttribute('aria-label', 'Copy code');
            button.setAttribute('data-tooltip', 'Copy');
            button.innerHTML = '<i class="ion ion-ios-copy"></i>';
            wrapper.appendChild(button);

            button.addEventListener('click', async () => {
              const code = pre.querySelector('code');
              const text = code?.textContent ?? pre.textContent ?? '';
              try {
                await navigator.clipboard.writeText(text);
                button.innerHTML = '<i class="ion ion-ios-checkmark"></i>';
                button.setAttribute('data-tooltip', 'Copied!');
                button.classList.add('is-copied');
                setTimeout(() => {
                  button.innerHTML = '<i class="ion ion-ios-copy"></i>';
                  button.setAttribute('data-tooltip', 'Copy');
                  button.classList.remove('is-copied');
                }, 2000);
              } catch {
                button.innerHTML = '<i class="ion ion-ios-copy"></i>';
              }
            });
          });
        </script>
        <!-- end post -->
      </div>
    </div>
  </div>
</Base>

---
import type { CollectionEntry } from 'astro:content';
import Base from './Base.astro';
import GiscusComments from '../components/GiscusComments.astro';
import { getPostUrl, tagSlug, readingTime } from '../lib/posts';

interface Props {
  post: CollectionEntry<'posts'>;
  prevPost?: CollectionEntry<'posts'>;
  nextPost?: CollectionEntry<'posts'>;
}

const { post, prevPost, nextPost } = Astro.props;
const { title, description, image, pubDate, tags = [] } = post.data;
const postUrl = getPostUrl(post);

const dateISO = pubDate.toISOString();
const dateFormatted = pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
const mins = readingTime(post.body ?? '');

const prevUrl = prevPost ? getPostUrl(prevPost) : null;
const nextUrl = nextPost ? getPostUrl(nextPost) : null;

const shareBase = Astro.site?.href.replace(/\/$/, '') ?? '';
const shareUrl = `${shareBase}${postUrl}`;
const shareTitle = encodeURIComponent(title);
const shareDesc = encodeURIComponent(description);
---
<Base title={title} description={description} image={image} pubDate={pubDate}>
  {image && (
    <div class="container">
      <div class="row">
        <div class="col col-12">
          <div class="image-box">
            <img class="post-image" src={image} alt={title} />
            <div class="post-head post-head--overlay">
              <h1 class="post-title">{title}</h1>
              <div class="post__date-reading">
                <time datetime={dateISO}>{dateFormatted}</time>
                <span class="post__separator">·</span>
                <span class="post__reading-time">
                  <i class="ion ion-ios-time"></i> {mins} min read
                </span>
              </div>
              {tags.length > 0 && (
                <div class="post-tags">
                  {tags.map((tag) => (
                    <a href={`/tag/${tagSlug(tag)}/`} class="post-tags__tag">#{tag}</a>
                  ))}
                </div>
              )}
            </div>
          </div>
        </div>
      </div>
    </div>
  )}

  <div class="container">
    <div class="row">
      <div class="col col-8 col-d-10 push-2 push-d-1 col-t-12 push-t-0">
        <!-- begin post -->
        <article class="post animate">

          {!image && (
            <div class="post-head">
              <h1 class="post-title">{title}</h1>
              <div class="post__date-reading">
                <time datetime={dateISO}>{dateFormatted}</time>
                <span class="post__separator">·</span>
                <span class="post__reading-time">
                  <i class="ion ion-ios-time"></i> {mins} min read
                </span>
              </div>
              {tags.length > 0 && (
                <div class="post-tags">
                  {tags.map((tag) => (
                    <a href={`/tag/${tagSlug(tag)}/`} class="post-tags__tag">#{tag}</a>
                  ))}
                </div>
              )}
            </div>
          )}

          <div class="post__content" data-pagefind-body>
            {/* Visually hidden title copy with boosted weight so title matches rank higher in Pagefind */}
            <span data-pagefind-weight="10" style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap">{title}</span>
            <slot />
          </div>

          <div class="post__share">
            <div class="share__head">
              <div class="share__title">Share this article</div>
            </div>
            <ul class="share__list list-reset">
              <li class="share__item">
                <a class="share__link share__facebook"
                  href={`https://www.facebook.com/sharer/sharer.php?u=${shareUrl}`}
                  onclick="window.open(this.href,'pop-up','left=20,top=20,width=500,height=500,toolbar=1,resizable=0');return false;"
                  title="Share on Facebook" rel="nofollow">
                  <i class="ion ion-logo-facebook"></i>
                </a>
              </li>
              <li class="share__item">
                <a class="share__link share__twitter"
                  href={`https://twitter.com/intent/tweet?text=${shareTitle}&url=${shareUrl}`}
                  onclick="window.open(this.href,'pop-up','left=20,top=20,width=500,height=500,toolbar=1,resizable=0');return false;"
                  title="Share on Twitter" rel="nofollow">
                  <i class="ion ion-logo-twitter"></i>
                </a>
              </li>
              <li class="share__item">
                <a class="share__link share__linkedin"
                  href={`https://www.linkedin.com/shareArticle?mini=true&url=${shareUrl}&title=${shareTitle}&summary=${shareDesc}`}
                  onclick="window.open(this.href,'pop-up','left=20,top=20,width=500,height=500,toolbar=1,resizable=0');return false;"
                  title="Share on LinkedIn" rel="nofollow">
                  <i class="ion ion-logo-linkedin"></i>
                </a>
              </li>
            </ul>
          </div>

          <div class="post__navigation">
            {prevUrl && (
              <a class="prev" href={prevUrl} style={prevPost?.data.image ? `background-image: url(${prevPost.data.image})` : undefined}>
                <div class="post__nav-box">
                  <div class="post__nav post__nav__prev">
                    <i class="ion ion-ios-arrow-back"></i> Previous Page
                  </div>
                  <h4 class="post__nav__title">{prevPost?.data.title}</h4>
                </div>
              </a>
            )}
            {nextUrl && (
              <a class="next" href={nextUrl} style={nextPost?.data.image ? `background-image: url(${nextPost.data.image})` : undefined}>
                <div class="post__nav-box">
                  <div class="post__nav post__nav__next">
                    Next Page <i class="ion ion-ios-arrow-forward"></i>
                  </div>
                  <h4 class="post__nav__title">{nextPost?.data.title}</h4>
                </div>
              </a>
            )}
          </div>

          <GiscusComments />

        </article>

        <script>
          document.querySelectorAll('.post__content pre').forEach((pre) => {
            const wrapper = document.createElement('div');
            wrapper.className = 'code-block-wrapper';
            pre.parentNode?.insertBefore(wrapper, pre);
            wrapper.appendChild(pre);

            const button = document.createElement('button');
            button.className = 'code-copy-btn';
            button.setAttribute('aria-label', 'Copy code');
            button.textContent = 'Copy';
            wrapper.appendChild(button);

            button.addEventListener('click', async () => {
              const code = pre.querySelector('code');
              const text = code?.textContent ?? pre.textContent ?? '';
              try {
                await navigator.clipboard.writeText(text);
                button.textContent = 'Copied!';
                setTimeout(() => { button.textContent = 'Copy'; }, 2000);
              } catch {
                button.textContent = 'Copy';
              }
            });
          });
        </script>
        <!-- end post -->
      </div>
    </div>
  </div>
</Base>
